{
  "name": "opencode-discord-channel",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenCode plugin: bridges a Discord bot to an OpenCode session",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm && tsc --emitDeclarationOnly --noEmit false",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["opencode", "discord", "plugin", "channel", "bridge"],
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.3.0",
    "@opencode-ai/sdk": "^1.3.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.0",
    "@opencode-ai/sdk": "^1.3.0",
    "@tsconfig/node22": "^22.0.0",
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
